{
  "realm": "fraud-engine",
  "enabled": true,
  "displayName": "Fraud Engine Local Demo",
  "sslRequired": "none",
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 3600,
  "clients": [
    {
      "clientId": "edge-gateway",
      "name": "Fraud Engine Edge Gateway",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false
    },
    {
      "clientId": "risk-ops-dashboard",
      "name": "Risk Operations Dashboard Demo Client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "local-dashboard-client-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "authorizationServicesEnabled": false,
      "redirectUris": [
        "http://localhost:3001/*",
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3001",
        "http://localhost:3000"
      ],
      "protocolMappers": [
        {
          "name": "edge-gateway-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "edge-gateway",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "payment-ingest",
        "description": "Allows local demo payment ingestion through the edge gateway"
      }
    ]
  },
  "users": [
    {
      "username": "risk.analyst",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Risk",
      "lastName": "Analyst",
      "email": "risk.analyst@fraud-engine.local",
      "credentials": [
        {
          "type": "password",
          "value": "local-risk-analyst-password",
          "temporary": false
        }
      ],
      "realmRoles": ["payment-ingest"]
    }
  ]
}
