# Copy this file to .env for local production-style runs.
# Never commit .env. Use a rotated Gemini key; do not reuse a key pasted in chat.

FRAUD_ENGINE_POSTGRES_DB=fraud_engine
FRAUD_ENGINE_POSTGRES_USER=fraud_engine_app
FRAUD_ENGINE_POSTGRES_PASSWORD=replace-with-local-postgres-password
REDIS_PASSWORD=replace-with-local-redis-password

# Config Server reads local config files and local Vault dev secrets.
CONFIG_SERVER_PROFILES=native,vault
VAULT_HOST=vault
VAULT_PORT=8200
VAULT_TOKEN=root
VAULT_HOST_PORT=8200

# Local OIDC identity provider for front-door JWT demos.
KEYCLOAK_HOST_PORT=8089
KEYCLOAK_PUBLIC_URL=http://localhost:8089
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-local-keycloak-admin-password
DASHBOARD_OIDC_CLIENT_ID=risk-ops-dashboard
DASHBOARD_OIDC_CLIENT_SECRET=local-dashboard-client-secret
AUTH_SECRET=replace-with-random-32-byte-dashboard-auth-secret
AUTH_URL=http://localhost:3001
DASHBOARD_OIDC_ISSUER=http://localhost:8089/realms/fraud-engine
DASHBOARD_OIDC_ISSUER_INTERNAL=http://keycloak:8080/realms/fraud-engine
DASHBOARD_OIDC_AUTHORIZATION_URL=http://localhost:8089/realms/fraud-engine/protocol/openid-connect/auth
DASHBOARD_OIDC_TOKEN_URL=http://keycloak:8080/realms/fraud-engine/protocol/openid-connect/token
DASHBOARD_OIDC_LOGOUT_URL=http://localhost:8089/realms/fraud-engine/protocol/openid-connect/logout
DASHBOARD_POST_LOGOUT_REDIRECT_URL=http://localhost:3001/
KEYCLOAK_TOKEN_URL=http://keycloak:8080/realms/fraud-engine/protocol/openid-connect/token

# Production-style AI runtime: deterministic Java rules decide, Gemini explains when enabled.
AI_FRAUD_AGENT_PROFILES=prod,mock-ai
FRAUD_AGENT_AI_PROVIDER_NAME=deterministic-rules
FRAUD_AGENT_MODEL_CALL_ENABLED=false
FRAUD_AGENT_SEED_MOCK_DATA=false
GEMINI_API_KEY=replace-with-rotated-gemini-api-key

# Optional Gemini model overrides.
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Local ports.
POSTGRES_HOST_PORT=15432
EDGE_GATEWAY_HOST_PORT=8080
AI_FRAUD_AGENT_HOST_PORT=8082
LEDGER_SERVICE_HOST_PORT=8081
RISK_OPS_DASHBOARD_HOST_PORT=3001
GRAFANA_HOST_PORT=3000
CONFIG_SERVER_HOST_PORT=8888

# JWT validation for the Edge Gateway. Replace with your enterprise IdP values.
EDGE_GATEWAY_JWT_ISSUER_URI=http://localhost:8089/realms/fraud-engine
EDGE_GATEWAY_JWT_JWK_SET_URI=http://keycloak:8080/realms/fraud-engine/protocol/openid-connect/certs

# Optional Kafka SASL client profile. Activate with Spring profile kafka-sasl only
# after the Kafka broker is configured for matching SASL authentication.
KAFKA_SECURITY_PROTOCOL=SASL_PLAINTEXT
KAFKA_SASL_MECHANISM=SCRAM-SHA-512
KAFKA_SASL_USERNAME=fraud-engine-app
KAFKA_SASL_PASSWORD=replace-with-local-kafka-sasl-password

# Dashboard browser URL for Gateway SSE.
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080/api/v1/stream/payments
